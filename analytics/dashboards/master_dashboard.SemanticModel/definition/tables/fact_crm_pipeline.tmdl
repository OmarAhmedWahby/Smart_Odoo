	column 'Days Open Bucket' =
			
			SWITCH(
			    TRUE(),
			    fact_crm_pipeline[day_open] <= 7, "0-7 Days",
			    fact_crm_pipeline[day_open] <= 14, "8-14 Days",
			    fact_crm_pipeline[day_open] <= 30, "15-30 Days",
			    fact_crm_pipeline[day_open] <= 60, "31-60 Days",
			    "60+ Days"
			)
		lineageTag: 553d8371-e16d-4a91-9136-8581967def9d
		summarizeBy: none

