	column Age =
			
			DATEDIFF(
			    dim_employee[birthday],
			    TODAY(),
			    YEAR
			)
		formatString: 0
		lineageTag: 3865a25d-1168-4a2a-b383-f98c76a2d277
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column 'Age Bin' =
			
			SWITCH(
			    TRUE(),
			    dim_employee[Age] < 25, "Under 25",
			    dim_employee[Age] <= 34, "25-34",
			    dim_employee[Age] <= 44, "35-44",
			    dim_employee[Age] <= 54, "45-54",
			    dim_employee[Age] <= 64, "55-64",
			    "65+"
			)
		lineageTag: 24738d44-b34f-4326-8e59-a44077bdc512
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

