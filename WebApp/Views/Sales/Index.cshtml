@model Smart_Odoo.Models.DashboardSalesViewModel

@{
    ViewData["Title"] = "Sales Dashboard";
    ViewData["ActiveMenu"] = "Sales"; 
}

@section Styles {
    <style>
        .bento-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        .bento-item {
            background: var(--bg-surface); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color); border-radius: 24px; padding: 24px;
            box-shadow: var(--shadow-card); transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex; flex-direction: column; animation: fadeUp 0.6s backwards;
            min-width: 0; max-width: 100%;
        }
        .bento-item:hover {
            transform: translateY(-4px); border-color: var(--c-theme, var(--border-hover));
            box-shadow: 0 15px 35px rgba(0,0,0,0.1), 0 8px 20px var(--c-bg, transparent);
        }

        /* Stats Cards */
        .stat-label { color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
        .stat-value { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: var(--text-primary); letter-spacing: -1px; margin-bottom: 12px; }
        .stat-sub { font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 6px;}
        .stat-sub.green { color: #10b981; }
        .stat-sub.red { color: #ef4444; }
        .stat-sub.blue { color: #3b82f6; }
        
        /* Charts */
        .chart-title { font-size: 1.15rem; font-weight: 700; margin-bottom: 20px; color: var(--text-primary); }
        .chart-wrapper { position: relative; width: 100%; height: 260px; min-width: 0; }

        /* Premium Table */
        .table-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
        .table-header-row h5 { margin: 0; font-size: 1.25rem; font-weight: 700; }
        .table-tools { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        .btn-outline { background: transparent; border: 1px solid var(--border-color); color: var(--text-primary); padding: 10px 16px; border-radius: 12px; font-weight: 600; font-size: 0.9rem; transition: all 0.3s; display: flex; gap: 8px; align-items: center; cursor: pointer; }
        .btn-outline:hover { background: var(--border-hover); border-color: var(--text-secondary); }
        
        .table-responsive { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0 -24px; padding: 0 24px; }
        .table-responsive::-webkit-scrollbar { height: 6px; }
        .table-responsive::-webkit-scrollbar-thumb { background: var(--border-hover); border-radius: 10px; }

        .erp-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 800px; }
        .erp-table th { text-align: left; padding: 16px; color: var(--text-secondary); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--border-color); }
        .erp-table td { padding: 18px 16px; font-size: 0.95rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); transition: background 0.3s; vertical-align: middle;}
        .erp-table tbody tr:hover td { background: rgba(128, 128, 128, 0.02); }
        .erp-table tbody tr:last-child td { border-bottom: none; }
        .cell-bold { font-weight: 700; color: var(--text-primary); }
        
        /* Badges */
        .badge { padding: 6px 14px; border-radius: 100px; font-weight: 600; font-size: 0.75rem; display: inline-block; }
        .badge-green { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); }
        .badge-yellow { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
        .badge-blue { background: rgba(59, 130, 246, 0.15); color: #3b82f6; border: 1px solid rgba(59, 130, 246, 0.3); }
        .badge-red { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }

        .view-link { color: var(--accent-main); font-weight: 600; font-size: 0.9rem; cursor: pointer; transition: all 0.3s; }
        .view-link:hover { color: #a855f7; text-decoration: underline; }

        @@media (max-width: 1200px) {
            .bento-grid { grid-template-columns: repeat(2, 1fr); }
            .chart-bento { grid-column: span 2; }
            .table-bento { grid-column: span 2; }
        }
        @@media (max-width: 768px) {
            .bento-grid { grid-template-columns: 1fr; gap: 16px; }
            .bento-item, .chart-bento, .table-bento { grid-column: span 1 !important; }
            .table-header-row { flex-direction: column; align-items: flex-start; gap: 12px; }
            .table-tools { width: 100%; justify-content: space-between; }
            .search-box { width: 100%; }
            .table-tools .btn-outline { flex: 1; justify-content: center; }
        }
    </style>
}

<div class="module-header card-sales">
    <div class="mod-icon"><i class="fa-solid fa-chart-line"></i></div>
    <div>
        <h1 class="page-title">Sales Management</h1>
        <p class="page-sub">Track sales orders and revenue performance</p>
    </div>
</div>

<div class="bento-grid">
    
    <div class="bento-item card-sales" style="animation-delay: 0.1s;">
        <div class="stat-label">Total Sales</div>
        @* افترضت ان اسم الـ property القيمة TotalValue والنسبة Growth *@
        <div class="stat-value">@Model.SalesKpi?.TotalSales.ToString("N0")</div>
        <div class="stat-sub @(Model.SalesKpi?.MomGrowthPercent >= 0 ? "green" : "red")">
            <i class="fa-solid @(Model.SalesKpi?.MomGrowthPercent >= 0 ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i> 
            @Model.SalesKpi?.MomGrowthPercent% from last month
        </div>
    </div>
            
    <div class="bento-item card-sales" style="animation-delay: 0.2s;">
        <div class="stat-label">Orders This Month</div>
        <div class="stat-value">@Model.OrdersKpi?.TotalOrders.ToString("N0")</div>
        <div class="stat-sub @(Model.OrdersKpi?.MomGrowthPercent >= 0 ? "green" : "red")">
            <i class="fa-solid @(Model.OrdersKpi?.MomGrowthPercent >= 0 ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i> 
            @Model.OrdersKpi?.MomGrowthPercent% from last month
        </div>
    </div>
            
    <div class="bento-item card-sales" style="animation-delay: 0.3s;">
        <div class="stat-label">Avg. Order Value</div>
        <div class="stat-value">@Model.AovKpi?.AvgOrderValue.ToString("N0")</div>
        <div class="stat-sub @(Model.AovKpi?.MomGrowthPercent >= 0 ? "green" : "red")">
            <i class="fa-solid @(Model.AovKpi?.MomGrowthPercent >= 0 ? "fa-arrow-trend-up" : "fa-arrow-trend-down")"></i> 
            @Model.AovKpi?.MomGrowthPercent% from last month
        </div>
    </div>
            
    <div class="bento-item card-sales" style="animation-delay: 0.4s;">
        <div class="stat-label">Active Customers</div>
        <div class="stat-value">@Model.CustomerKpi?.ActiveCustomers.ToString("N0")</div>
        <div class="stat-sub blue">
            <i class="fa-solid fa-user-plus"></i> @Model.CustomerKpi?.NewCustomersThisMonth new this month
        </div>
    </div>

    <div class="bento-item card-sales chart-bento" style="grid-column: span 2; animation-delay: 0.5s;">
        <div class="chart-title">Sales Revenue Trend</div>
        <div class="chart-wrapper">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>
            
    <div class="bento-item card-sales chart-bento" style="grid-column: span 2; animation-delay: 0.6s;">
        <div class="chart-title">Top Products</div>
        <div class="chart-wrapper">
            <canvas id="productChart"></canvas>
        </div>
    </div>

    <div class="bento-item card-sales table-bento" style="grid-column: span 4; animation-delay: 0.7s;">
        <div class="table-header-row">
            <h5>Recent Sales Orders</h5>
        </div>
                
        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Order ID</th>
                        <th>Customer</th>
                        <th>Items</th>
                        <th>Amount</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model.RecentOrders != null && Model.RecentOrders.Any())
                    {
                        foreach(var order in Model.RecentOrders)
                        {
                            <tr>
                                <td><span class="cell-bold">@order.OrderId</span></td>
                                <td>@order.CustomerName</td>
                                <td>@order.ItemsCount</td>
                                <td><span class="cell-bold">@order.OrderAmount.ToString("N0")</span></td>
                                <td>
                                    @{
                                        // تحديد لون الشارة بناءً على الحالة
                                        var badgeClass = order.OrderState.ToLower() switch {
                                            "completed" => "badge-green",
                                            "processing" => "badge-yellow",
                                            "shipped" => "badge-blue",
                                            "cancelled" => "badge-red",
                                            _ => "badge-yellow"
                                        };
                                    }
                                    <span class="badge @badgeClass">@order.OrderState</span>
                                </td>
                                <td>@order.OrderDate.ToString("yyyy-MM-dd")</td>
                                <td><a href="#" class="view-link">View Details</a></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center" style="padding: 30px;">No recent orders found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            if (typeof Chart === 'undefined') return;

            Chart.defaults.font.family = "'Plus Jakarta Sans', sans-serif";
            Chart.defaults.color = "#64748b";
            
            const gridColor = "rgba(128, 128, 128, 0.1)";
            const tooltipBg = "rgba(15, 23, 42, 0.9)";

            // جلب البيانات من الموديل للجافاسكريبت مباشرة باستخدام JSON Serialize
            // تأكد ان اسماء ال Properties (زي Month و Revenue) متطابقة مع الكلاسات بتاعتك في C#
            const revenueData = @Html.Raw(Json.Serialize(Model.RevenueTrend?.Select(x => x.TotalRevenue) ?? new List<decimal>()));
            const revenueLabels = @Html.Raw(Json.Serialize(Model.RevenueTrend?.Select(x => x.MonthShort) ?? new List<string>()));

            const productData = @Html.Raw(Json.Serialize(Model.TopProducts?.Select(x => (int)x.TotalSales) ?? new List<int>()));
            const productLabels = @Html.Raw(Json.Serialize(Model.TopProducts?.Select(x => x.ProductName) ?? new List<string>()));

            // --- Chart 1: Revenue ---
            const ctxRev = document.getElementById('revenueChart');
            if(ctxRev) {
                let gradientRev = ctxRev.getContext('2d').createLinearGradient(0, 0, 0, 300);
                gradientRev.addColorStop(0, 'rgba(16, 185, 129, 0.4)');
                gradientRev.addColorStop(1, 'rgba(16, 185, 129, 0.0)');

                new Chart(ctxRev, {
                    type: 'line',
                    data: {
                        labels: revenueLabels,
                        datasets: [{
                            label: 'Revenue',
                            data: revenueData,
                            borderColor: '#10b981',
                            backgroundColor: gradientRev,
                            borderWidth: 3,
                            pointBackgroundColor: '#10b981',
                            pointBorderColor: '#ffffff',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { backgroundColor: tooltipBg, titleColor: '#fff', bodyColor: '#fff', padding: 12, cornerRadius: 8, displayColors: false } },
                        scales: { x: { grid: { display: false } }, y: { grid: { color: gridColor }, beginAtZero: true } }
                    }
                });
            }

            // --- Chart 2: Product Performance ---
            const ctxProd = document.getElementById('productChart');
            if(ctxProd) {
                new Chart(ctxProd, {
                    type: 'bar',
                    data: {
                        labels: productLabels,
                        datasets: [{
                            label: 'Units Sold',
                            data: productData,
                            backgroundColor: '#3b82f6',
                            borderRadius: 6,
                            borderSkipped: false,
                            barThickness: 24
                        }]
                    },
                    options: {
                        responsive: true, maintainAspectRatio: false,
                        plugins: { legend: { display: false }, tooltip: { backgroundColor: tooltipBg, titleColor: '#fff', bodyColor: '#fff', padding: 12, cornerRadius: 8 } },
                        scales: { x: { grid: { display: false } }, y: { grid: { color: gridColor }, beginAtZero: true } }
                    }
                });
            }
        });
    </script>
}