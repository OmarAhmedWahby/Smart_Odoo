@{
    ViewData["Title"] = "Dashboard";
    ViewData["ActiveMenu"] = "Home";
}

<style>
      .bento-grid { 
            display: grid; 
            grid-template-columns: repeat(4, 1fr); 
            grid-auto-rows: minmax(190px, auto); 
            gap: 24px; 
        }

        .bento-item {
            background: var(--bg-surface);
            backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color); border-radius: 24px; padding: 28px;
            box-shadow: var(--shadow-card);
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative; overflow: hidden; display: flex; flex-direction: column;
            animation: fadeUp 0.6s backwards;
        }

        .bento-item:hover {
            transform: translateY(-5px);
            border-color: var(--c-theme, var(--border-hover));
            box-shadow: 0 15px 35px rgba(0,0,0,0.1), 0 8px 20px var(--c-bg, transparent);
        }

        .hero-bento { grid-column: span 3; grid-row: span 2; display: flex; flex-direction: row; align-items: center; background: linear-gradient(to bottom right, var(--bg-surface), rgba(128,128,128,0.02));}
        .stats-bento { grid-column: span 1; grid-row: span 2; }
        .ml-bento { grid-column: span 2; grid-row: span 2; border-color: rgba(6,182,212,0.2); background: linear-gradient(180deg, var(--bg-surface) 0%, rgba(6,182,212,0.03) 100%); }
        .finance-bento { grid-column: span 2; }

        /* ================= BENTO CONTENT & RESPONSIVE TEXT ================= */
        .hero-content { flex: 1; z-index: 2;}
        
        /* Clamp ensures it shrinks beautifully on mobile without overflowing */
        .hero-title { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; margin-bottom: 16px; line-height: 1.15; letter-spacing: -1px;}
        .hero-title span { background: linear-gradient(135deg, var(--accent-main), #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero-sub { color: var(--text-secondary); font-size: clamp(0.95rem, 2vw, 1.15rem); max-width: 420px; margin-bottom: 28px; line-height: 1.6;}
        
        .hero-visual { width: 40%; height: 100%; position: relative; display: flex; align-items: flex-end; gap: 12px; padding-left: 20px;}
        .bar { width: 32px; background: linear-gradient(to top, var(--accent-main), transparent); border-radius: 8px 8px 0 0; animation: growBar 1.5s cubic-bezier(0.25, 0.8, 0.25, 1) forwards; transform-origin: bottom; opacity: 0; }
        .bar:nth-child(1) { height: 45%; animation-delay: 0.1s; } .bar:nth-child(2) { height: 75%; animation-delay: 0.2s; }
        .bar:nth-child(3) { height: 55%; animation-delay: 0.3s; } .bar:nth-child(4) { height: 95%; animation-delay: 0.4s; background: linear-gradient(to top, #a855f7, transparent); }

        .mod-icon {
            width: 52px; height: 52px; border-radius: 16px; flex-shrink: 0;
            display: flex; justify-content: center; align-items: center;
            font-size: 1.5rem; margin-bottom: auto;
            background: var(--c-bg); color: var(--c-theme);
        }
        .bento-item h4 { font-size: 1.2rem; font-weight: 700; margin-top: 20px; margin-bottom: 8px; letter-spacing: -0.5px;}
        .bento-item p { color: var(--text-secondary); font-size: 0.9rem; line-height: 1.6; margin-bottom: 16px;}
        .bento-item .arrow { margin-top: auto; color: var(--text-secondary); font-size: 1.2rem; align-self: flex-end; transition: all 0.3s; opacity: 0; transform: translateX(-15px);}
        .bento-item:hover .arrow { opacity: 1; transform: translateX(0); color: var(--c-theme); }

        .stats-list { display: flex; flex-direction: column; gap: 24px; margin-top: 24px;}
        .stat-row { display: flex; justify-content: space-between; align-items: center; padding-bottom: 16px; border-bottom: 1px solid var(--border-color);}
        .stat-row:last-child { border: none; padding-bottom: 0;}
        .s-label { color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px;}
        .s-value { font-size: clamp(1.2rem, 3vw, 1.6rem); font-weight: 800; color: var(--text-primary); letter-spacing: -1px;}
        .s-value.green { color: #10b981; text-shadow: 0 0 15px rgba(16,185,129,0.3); }

        .ml-bento h4 { font-size: 1.6rem; }
        
        @@keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        @@keyframes growBar { from { transform: scaleY(0); opacity: 0; } to { transform: scaleY(1); opacity: 1; } }

        /* ================= MOBILE NAVIGATION (NEW DRAWER SYSTEM) ================= */
        .mobile-topbar {
            display: none;
            background: var(--glass-bg); backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
            border-bottom: 1px solid var(--border-color);
            padding: 16px 24px;
            position: sticky; top: 0; z-index: 101;
        }
        
        .mobile-brand { font-size: 1.4rem; font-weight: 800; background: linear-gradient(135deg, var(--accent-main), #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;}
        
        .menu-btn {
            background: transparent; border: none; color: var(--text-primary); font-size: 1.5rem; cursor: pointer;
        }

        .mobile-drawer {
            position: fixed; top: 0; left: -100%; width: 280px; height: 100vh;
            background: var(--bg-surface); backdrop-filter: blur(30px); -webkit-backdrop-filter: blur(30px);
            border-right: 1px solid var(--border-color);
            z-index: 103; transition: left 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex; flex-direction: column; padding: 24px;
        }
        .mobile-drawer.active { left: 0; }

        .drawer-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; }
        .drawer-close { background: transparent; border: none; color: var(--text-secondary); font-size: 1.5rem; cursor: pointer; }

        .mobile-overlay {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(0,0,0,0.4); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);
            z-index: 102; opacity: 0; pointer-events: none; transition: opacity 0.4s ease;
        }
        .mobile-overlay.active { opacity: 1; pointer-events: auto; }

        /* ================= RESPONSIVE MEDIA QUERIES ================= */
        @@media (max-width: 1200px) {
            .bento-grid { grid-template-columns: repeat(3, 1fr); }
            .hero-bento { grid-column: span 3; }
            .stats-bento { grid-column: span 3; grid-row: span 1; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
            .stats-list { flex-direction: row; margin-top: 0; width: 100%; justify-content: space-between;}
            .stat-row { border: none; padding: 0; flex-direction: column; align-items: flex-start; gap: 8px;}
            .search-box { width: 240px; }
        }
        
        /* Tablet & Mobile: Activate Mobile Menu, hide Sidebar */
        @@media (max-width: 992px) {
            .app-layout { padding: 0; flex-direction: column; gap: 0;}
            .sidebar { display: none; } /* Hide Desktop Sidebar */
            
            .mobile-topbar { display: flex; justify-content: space-between; align-items: center; }
            
            .main-content { padding: 20px; margin: 0; }
            .topbar { display: none; } /* Hide Desktop Topbar */
            
            .bento-grid { grid-template-columns: repeat(2, 1fr); gap: 16px; }
            .hero-bento, .ml-bento, .finance-bento { grid-column: span 2; }
            
            .hero-bento { flex-direction: column; text-align: center; padding: 24px; }
            .hero-sub { margin: 0 auto 24px; }
            .hero-visual { width: 100%; height: 140px; margin-top: 24px; justify-content: center; padding: 0;}
        }

        @@media (max-width: 576px) {
            .bento-grid { grid-template-columns: 1fr; }
            .hero-bento, .ml-bento, .finance-bento, .stats-bento { grid-column: span 1; }
            .stats-list { display: grid; grid-template-columns: 1fr 1fr; gap: 24px;}
            .bar { width: 24px; }
        }
    </style>
</style>

<div class="bento-grid">
            
    <div class="bento-item hero-bento" style="animation-delay: 0.1s;">
        <div class="hero-content">
            <div style="display:inline-block; padding: 6px 16px; background: var(--border-color); border: 1px solid var(--border-hover); border-radius: 100px; font-size: 0.85rem; font-weight: 700; margin-bottom: 20px; color: var(--text-primary);">
                <i class="fa-solid fa-sparkles" style="color: var(--accent-main); margin-right: 6px;"></i> System v2.0 is live
            </div>
            <h1 class="hero-title">Welcome back,<br><span>Admin User.</span></h1>
            <p class="hero-sub">Your enterprise data is synced. AI models have detected 3 new optimization opportunities today.</p>
            <a asp-controller="bi" class="btn btn-primary" style="border-radius: 14px; padding: 12px 28px; font-weight: 600; background: var(--accent-main); border:none; font-size: 0.95rem; box-shadow: 0 4px 15px rgba(99, 102, 241, 0.4);">View AI Report</a>
        </div>
        <div class="hero-visual">
            <div class="bar"></div><div class="bar"></div><div class="bar"></div><div class="bar"></div>
        </div>
    </div>

    <div class="bento-item stats-bento" style="animation-delay: 0.2s;">
        <h4 style="margin: 0; font-size: 1.15rem; color: var(--text-primary);"><i class="fa-solid fa-chart-simple" style="color: var(--accent-main); margin-right: 8px;"></i> Overview</h4>
        <div class="stats-list">
            <div class="stat-row">
                <span class="s-label">Active Users</span><span class="s-value">247</span>
            </div>
            <div class="stat-row">
                <span class="s-label">Daily Ops</span><span class="s-value">1,834</span>
            </div>
            <div class="stat-row">
                <span class="s-label">System Health</span><span class="s-value green">99.9%</span>
            </div>
            <div class="stat-row">
                <span class="s-label">Modules</span><span class="s-value">8</span>
            </div>
        </div>
    </div>

    <a asp-controller="ml" class="bento-item ml-bento card-ml" style="animation-delay: 0.3s;">
        <div class="mod-icon"><i class="fa-solid fa-network-wired"></i></div>
        <h4>ML Insights & AI</h4>
        <p>AI-powered predictions, deep enterprise data analysis, and automated risk detection algorithms running in real-time.</p>
        <i class="fa-solid fa-arrow-right-long arrow"></i>
    </a>

    <a asp-controller="purchase" class="bento-item card-purchase" style="animation-delay: 0.4s;">
        <div class="mod-icon"><i class="fa-solid fa-cart-shopping"></i></div>
        <h4>Purchase</h4>
        <p>Manage POs, vendors, and procurement.</p>
        <i class="fa-solid fa-arrow-right-long arrow"></i>
    </a>

    <a asp-controller="sales"  class="bento-item card-sales" style="animation-delay: 0.5s;">
        <div class="mod-icon"><i class="fa-solid fa-bolt"></i></div>
        <h4>Sales</h4>
        <p>Track orders, customers, and revenue.</p>
        <i class="fa-solid fa-arrow-right-long arrow"></i>
    </a>


    <a asp-controller="hr" class="bento-item card-hr" style="animation-delay: 0.7s;">
        <div class="mod-icon"><i class="fa-solid fa-users"></i></div>
        <h4>HR</h4>
        <p>Employee management & payroll.</p>
        <i class="fa-solid fa-arrow-right-long arrow"></i>
    </a>

        <a asp-controller="inventory" class="bento-item card-crm" style="animation-delay: 0.9s;">
        <div class="mod-icon"><i class="fa-solid fa-address-book"></i></div>
        <h4>Inventory</h4>
        <p>Track and manage inventory levels</p>
        <i class="fa-solid fa-arrow-right-long arrow"></i>
    </a>

    <a asp-controller="crm" class="bento-item card-crm" style="animation-delay: 0.9s;">
        <div class="mod-icon"><i class="fa-solid fa-address-book"></i></div>
        <h4>CRM</h4>
        <p>Manage leads and opportunities.</p>
        <i class="fa-solid fa-arrow-right-long arrow"></i>
    </a>

</div>