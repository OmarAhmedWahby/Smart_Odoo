@model Smart_Odoo.Models.MlDashboardViewModel

@{
    ViewData["Title"] = "AI & Machine Learning Hub";
    ViewData["ActiveMenu"] = "ML"; 
}

@section Styles {
    <style>
        /* ================= BENTO GRID & COMPONENTS (Unified ERP Style) ================= */
        .bento-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
        .bento-item {
            background: var(--bg-surface); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border-color); border-radius: 24px; padding: 24px;
            box-shadow: var(--shadow-card); transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            display: flex; flex-direction: column; animation: fadeUp 0.6s backwards;
            min-width: 0; max-width: 100%;
        }
        .bento-item:hover {
            transform: translateY(-4px); border-color: var(--c-theme, var(--border-hover));
            box-shadow: 0 15px 35px rgba(0,0,0,0.1), 0 8px 20px var(--c-bg, transparent);
        }

        /* Responsive Grid Column Spans (Fixed Spacing Bug) */
        .span-4 { grid-column: span 4; }
        .span-2 { grid-column: span 2; }

        /* ML/AI Theme Colors (Indigo) */
        .card-ai { --c-theme: #8b5cf6; --c-bg: rgba(139, 92, 246, 0.12); }

        /* Stats Cards */
        .stat-label { color: var(--text-secondary); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
        .stat-value { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; color: var(--text-primary); letter-spacing: -1px; margin-bottom: 12px; }
        .stat-sub { font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 6px;}
        .stat-sub.purple { color: #8b5cf6; }
        .stat-sub.red { color: #ef4444; }
        .stat-sub.green { color: #10b981; }
        .stat-sub.orange { color: #f59e0b; }

        /* Premium Alert Banner for 5th KPI */
        .alert-banner {
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(139, 92, 246, 0.02));
            border: 1px solid rgba(139, 92, 246, 0.3); border-radius: 20px;
            padding: 20px 24px; display: flex; justify-content: space-between; align-items: center;
            box-shadow: 0 8px 24px rgba(139, 92, 246, 0.05);
            animation: fadeUp 0.5s backwards;
        }
        .alert-inner { display: flex; align-items: center; gap: 16px; }
        .alert-inner i { font-size: 2rem; color: #8b5cf6; text-shadow: 0 0 15px rgba(139, 92, 246, 0.4); }
        .alert-title { font-size: 1.1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 4px; }
        .alert-desc { font-size: 0.9rem; color: var(--text-secondary); margin: 0; }

        /* Premium Table & Headers */
        .table-header-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; }
        .table-header-row h5 { margin: 0; font-size: 1.25rem; font-weight: 700; color: var(--text-primary); }
        .table-tools { display: flex; gap: 12px; align-items: center; flex-wrap: wrap; }
        
        .table-responsive { width: 100%; overflow-x: auto; -webkit-overflow-scrolling: touch; margin: 0 -24px; padding: 0 24px; }
        .table-responsive::-webkit-scrollbar { height: 6px; }
        .table-responsive::-webkit-scrollbar-thumb { background: var(--border-hover); border-radius: 10px; }

        .erp-table { width: 100%; border-collapse: separate; border-spacing: 0; min-width: 800px; }
        .erp-table th { text-align: left; padding: 16px; color: var(--text-secondary); font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; border-bottom: 1px solid var(--border-color); }
        .erp-table td { padding: 18px 16px; font-size: 0.95rem; color: var(--text-primary); border-bottom: 1px solid var(--border-color); transition: background 0.3s; vertical-align: middle;}
        .erp-table tbody tr:hover td { background: rgba(128, 128, 128, 0.02); }
        .erp-table tbody tr:last-child td { border-bottom: none; }
        
        .cell-bold { font-weight: 700; color: var(--text-primary); }
        .prob-value { font-weight: 700; font-size: 1.05rem; }
        
        /* Badges & Alerts */
        .badge { padding: 6px 14px; border-radius: 100px; font-weight: 600; font-size: 0.75rem; display: inline-block; }
        .badge-green { background: rgba(16, 185, 129, 0.15); color: #10b981; border: 1px solid rgba(16, 185, 129, 0.3); }
        .badge-orange { background: rgba(245, 158, 11, 0.15); color: #f59e0b; border: 1px solid rgba(245, 158, 11, 0.3); }
        .badge-danger { background: rgba(239, 68, 68, 0.15); color: #ef4444; border: 1px solid rgba(239, 68, 68, 0.3); }
        .badge-purple { background: rgba(139, 92, 246, 0.15); color: #8b5cf6; border: 1px solid rgba(139, 92, 246, 0.3); }

        /* Interactive Prediction Forms */
        .predict-box { margin-bottom: 20px; }
        .result-display {
            background: rgba(128, 128, 128, 0.05); border: 1px solid var(--border-color);
            border-radius: 16px; padding: 20px; margin-top: 20px; animation: fadeIn 0.5s;
        }
        .result-title { font-size: 1rem; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; display: flex; align-items: center; gap: 8px;}
        .result-text { font-size: 0.95rem; color: var(--text-secondary); margin: 0; line-height: 1.6; }
        
        /* Buttons */
        .btn-solid-indigo { background: #8b5cf6; color: #fff; border: none; padding: 12px 24px; border-radius: 12px; font-weight: 600; cursor: pointer; transition: all 0.3s; box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3); display: flex; align-items: center; gap: 8px; justify-content: center;}
        .btn-solid-indigo:hover { background: #7c3aed; transform: translateY(-2px); }
        .btn-solid-indigo:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }

        /* ================= MEDIA QUERIES (Perfect Responsiveness) ================= */
        @@media (max-width: 1200px) {
            .bento-grid { grid-template-columns: repeat(2, 1fr); }
            .span-4, .span-2 { grid-column: span 2; }
        }
        @@media (max-width: 768px) {
            .bento-grid { grid-template-columns: 1fr; gap: 16px; }
            .span-4, .span-2 { grid-column: span 1; }
            .alert-banner { flex-direction: column; text-align: center; gap: 16px; }
            .alert-inner { flex-direction: column; }
            .row-inputs { flex-direction: column; gap: 12px; }
        }
    </style>
}

@* ================= PAGE HEADER ================= *@
<div class="module-header card-ai">
    <div class="mod-icon"><i class="fa-solid fa-brain"></i></div>
    <div>
        <h1 class="page-title">Machine Learning Dashboard</h1>
        <p class="page-sub">Predictive analytics, scoring, and intelligent forecasting</p>
    </div>
</div>

<div class="bento-grid">
    
    @* ================= KPI CARDS ================= *@
    <div class="bento-item card-ai" style="animation-delay: 0.1s;">
        <div class="stat-label">Risk Customers</div>
        <div class="stat-value">@Model.OverdueRiskCustomers.Count</div>
        <div class="stat-sub red">
            <i class="fa-solid fa-triangle-exclamation"></i> High default risk
        </div>
    </div>
            
    <div class="bento-item card-ai" style="animation-delay: 0.2s;">
        <div class="stat-label">Growth Customers</div>
        <div class="stat-value">@Model.OverdueGrowthCustomers.Count</div>
        <div class="stat-sub green">
            <i class="fa-solid fa-arrow-trend-up"></i> Positive behavior
        </div>
    </div>
            
    <div class="bento-item card-ai" style="animation-delay: 0.3s;">
        <div class="stat-label">Invoice Delay</div>
        <div class="stat-value">@Model.InvoiceDelayScores.Count</div>
        <div class="stat-sub orange">
            <i class="fa-solid fa-file-invoice-dollar"></i> Potential delays
        </div>
    </div>

    <div class="bento-item card-ai" style="animation-delay: 0.4s;">
        <div class="stat-label">Stockout Prediction</div>
        <div class="stat-value">@Model.InventoryStockoutPredictions.Count</div>
        <div class="stat-sub red">
            <i class="fa-solid fa-box-open"></i> Inventory risks
        </div>
    </div>

    @* ================= LEAD SCORE (Wide Banner) ================= *@
    <div class="alert-banner span-4" style="animation-delay: 0.5s;">
        <div class="alert-inner">
            <i class="fa-solid fa-bullseye"></i>
            <div>
                <div class="alert-title">Target Lead Scoring</div>
                <div class="alert-desc">AI has identified <strong class="text-primary">@Model.LeadScores.Count</strong> high-value leads ready for conversion. Check the tables below for details.</div>
            </div>
        </div>
    </div>

    @* ================= INTERACTIVE PREDICTOR MODULES ================= *@
    
    @* Predictor 1: Sales Forecast *@
    <div class="bento-item card-ai span-2" style="animation-delay: 0.6s;">
        <div class="chart-title"><i class="fa-solid fa-chart-line me-2 text-purple"></i>Sales Forecast AI</div>
        
        <div class="table-tools predict-box" style="justify-content: flex-start; background: transparent; padding: 0;">
            <div class="search-box" style="width: 100%; max-width: 300px; padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <i class="fa-solid fa-calendar-days" style="font-size: 0.9rem;"></i>
                <input type="date" id="forecastDate" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width:85%;">
            </div>
            <button id="btnForecast" onclick="forecastSales()" class="btn-solid-indigo">
                <i class="fa-solid fa-wand-magic-sparkles"></i> Predict
            </button>
        </div>

        <div id="forecastResult" class="mt-3"></div>
    </div>

    @* Predictor 2: Inventory Movement *@
    <div class="bento-item card-ai span-2" style="animation-delay: 0.7s;">
        <div class="chart-title"><i class="fa-solid fa-boxes-stacked me-2 text-purple"></i>Inventory Movement Prediction</div>
        
        <div class="d-flex flex-wrap gap-3 mb-3 row-inputs">
            <div class="search-box flex-grow-1" style="padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <input type="number" id="inventoryAge" placeholder="Age Days" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width: 100%;">
            </div>
            <div class="search-box flex-grow-1" style="padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <input type="number" id="quantity" placeholder="Quantity" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width: 100%;">
            </div>
            <div class="search-box flex-grow-1" style="padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <input type="number" id="reserved" placeholder="Reserved" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width: 100%;">
            </div>
        </div>
        
        <div class="d-flex flex-wrap gap-3 mb-4 row-inputs">
            <div class="search-box flex-grow-1" style="padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <input type="number" id="unitCost" placeholder="Unit Cost" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width: 100%;">
            </div>
            <div class="search-box flex-grow-1" style="padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <input type="text" id="category" placeholder="Category" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width: 100%;">
            </div>
            <div class="search-box flex-grow-1" style="padding: 10px 14px; background: var(--bg-body); border-radius: 8px;">
                <input type="text" id="warehouse" placeholder="Warehouse" style="font-size: 0.9rem; border: none; outline: none; background: transparent; color: var(--text-primary); width: 100%;">
            </div>
        </div>

        <button id="btnInventoryPred" onclick="predictInventory()" class="btn-solid-indigo w-100">
            <i class="fa-solid fa-microchip"></i> Run AI Analysis
        </button>

        <div id="inventoryResult" class="mt-3"></div>
    </div>

    @* ================= PREMIUM TABLES ================= *@

    @* Table 1: At Risk Customers *@
    <div class="bento-item card-ai span-4" style="animation-delay: 0.8s;">
        <div class="table-header-row">
            <h5><i class="fa-solid fa-user-shield me-2 text-danger"></i>At Risk Customers</h5>
        </div>
        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Segment</th>
                        <th>Paid Ratio</th>
                        <th>Overdue Ratio</th>
                        <th>Collection Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OverdueRiskCustomers)
                    {
                        <tr>
                            <td><span class="cell-bold">@item.Partner_Name</span></td>
                            <td><span class="badge badge-orange">@item.Segment</span></td>
                            <td class="text-muted">@item.Paid_Ratio %</td>
                            <td class="prob-value text-danger">@item.Overdue_Ratio %</td>
                            <td>@item.Collection_Rate %</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Table 2: Growing Customers *@
    <div class="bento-item card-ai span-4" style="animation-delay: 0.9s;">
        <div class="table-header-row">
            <h5><i class="fa-solid fa-seedling me-2 text-green"></i>Growing Customers</h5>
        </div>
        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Customer</th>
                        <th>Segment</th>
                        <th>Paid Ratio</th>
                        <th>Overdue Ratio</th>
                        <th>Collection Rate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.OverdueGrowthCustomers)
                    {
                        <tr>
                            <td><span class="cell-bold">@item.Partner_Name</span></td>
                            <td><span class="badge badge-purple">@item.Segment</span></td>
                            <td class="prob-value text-green">@item.Paid_Ratio %</td>
                            <td class="text-muted">@item.Overdue_Ratio %</td>
                            <td>@item.Collection_Rate %</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Table 3: Invoice Delay Scoring *@
    <div class="bento-item card-ai span-2" style="animation-delay: 1.0s;">
        <div class="table-header-row">
            <h5><i class="fa-solid fa-file-invoice-dollar me-2 text-orange"></i>Invoice Delay Scoring</h5>
        </div>
        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Partner ID</th>
                        <th>Delay Prob.</th>
                        <th>Risk Bucket</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.InvoiceDelayScores)
                    {
                        var bucketBadge = item.Risk_Bucket.Contains("High") ? "badge-danger" : "badge-orange";
                        <tr>
                            <td><span class="cell-bold">@item.Partner_Id</span></td>
                            <td class="prob-value text-orange">@item.Delay_Probability %</td>
                            <td><span class="badge @bucketBadge">@item.Risk_Bucket</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Table 4: Lead AI Scoring *@
    <div class="bento-item card-ai span-2" style="animation-delay: 1.1s;">
        <div class="table-header-row">
            <h5><i class="fa-solid fa-users-viewfinder me-2 text-purple"></i>Lead AI Scoring</h5>
        </div>
        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Lead</th>
                        <th>Win Prob.</th>
                        <th>Revenue</th>
                        <th>Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.LeadScores)
                    {
                        <tr>
                            <td><span class="cell-bold">@item.Lead_Name</span></td>
                            <td class="prob-value text-purple">@item.Probability_Of_Win %</td>
                            <td>@item.Expected_Revenue</td>
                            <td><span class="badge badge-purple">@item.Lead_Score</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* Table 5: Inventory Stockout Prediction *@
    <div class="bento-item card-ai span-4" style="animation-delay: 1.2s;">
        <div class="table-header-row">
            <h5><i class="fa-solid fa-box-open me-2 text-danger"></i>Inventory Stockout Prediction</h5>
        </div>
        <div class="table-responsive">
            <table class="erp-table">
                <thead>
                    <tr>
                        <th>Product</th>
                        <th>Available Qty</th>
                        <th>Days Stock</th>
                        <th>Probability</th>
                        <th>Risk</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.InventoryStockoutPredictions)
                    {
                        var riskBadge = item.Risk_Level == "High" ? "badge-danger" : (item.Risk_Level == "Medium" ? "badge-orange" : "badge-green");
                        <tr>
                            <td><span class="cell-bold">@item.Product_Name</span></td>
                            <td>@item.Available_Qty</td>
                            <td>@item.Days_Of_Stock</td>
                            <td class="prob-value text-danger">@item.Stockout_Probability %</td>
                            <td><span class="badge @riskBadge">@item.Risk_Level</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        // --- Sales Forecast Action ---
        async function forecastSales() {
            let date = document.getElementById("forecastDate").value;
            const btn = document.getElementById("btnForecast");
            
            if(!date) {
                alert("Please select a date.");
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Loading...';

            try {
                let response = await fetch('/ML/SalesForecast', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(date)
                });

                let data = await response.json();

                document.getElementById("forecastResult").innerHTML = `
                    <div class="result-display mt-0">
                        <div class="result-title"><i class="fa-solid fa-robot text-purple"></i> Prediction Result</div>
                        <p class="result-text mb-2">Forecast Value: <strong class="text-primary" style="font-size:1.1rem;">${data.yhat}</strong></p>
                        <p class="result-text mb-1" style="font-size:0.85rem;">Lower Bound: <strong>${data.yhat_lower}</strong></p>
                        <p class="result-text" style="font-size:0.85rem;">Upper Bound: <strong>${data.yhat_upper}</strong></p>
                    </div>
                `;
            } catch (error) {
                document.getElementById("forecastResult").innerHTML = `<div class="alert alert-danger mt-3">Error fetching forecast.</div>`;
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Predict';
            }
        }

        // --- Inventory Prediction Action ---
        async function predictInventory() {
            const btn = document.getElementById("btnInventoryPred");
            
            let model = {
                inventory_age_days: parseInt(document.getElementById("inventoryAge").value) || 0,
                quantity_on_hand: parseFloat(document.getElementById("quantity").value) || 0,
                reserved_quantity: parseFloat(document.getElementById("reserved").value) || 0,
                unit_cost: parseFloat(document.getElementById("unitCost").value) || 0,
                category: document.getElementById("category").value,
                warehouse_name: document.getElementById("warehouse").value
            };

            btn.disabled = true;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Analyzing...';

            try {
                let response = await fetch('/ML/InventoryPrediction', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(model)
                });

                let data = await response.json();

                const status = data.predicted_status;
                const isRisk = status && (status.toLowerCase().includes("slow") || status.toLowerCase().includes("risk"));
                const colorClass = isRisk ? "text-danger" : "text-green";

                document.getElementById("inventoryResult").innerHTML = `
                    <div class="result-display mt-0">
                        <div class="result-title"><i class="fa-solid fa-robot text-purple"></i> Analysis Status</div>
                        <p class="result-text Cell-bold ${colorClass}" style="font-size:1.1rem;">${status}</p>
                    </div>
                `;
            } catch (error) {
                document.getElementById("inventoryResult").innerHTML = `<div class="alert alert-danger mt-3">Error running prediction.</div>`;
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Predict';
            }
        }
    </script>
}